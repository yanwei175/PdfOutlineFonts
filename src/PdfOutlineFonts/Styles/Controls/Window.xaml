<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 鸿蒙风格 Window -->
    <Style x:Key="Window" TargetType="Window">
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="AllowsTransparency" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ResizeMode" Value="CanResize" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Window">

                    <Border x:Name="RootBorder"
                            Background="{DynamicResource Brush_Bck_Page}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">

                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>

                        <Grid>

                            <!-- 标题栏 -->
                            <Grid Height="48"
                                  Background="{DynamicResource Neutral1Brush}"
                                  VerticalAlignment="Top">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- 标题 -->
                                <TextBlock Text="{TemplateBinding Title}"
                                           VerticalAlignment="Center"
                                           Margin="16,0,0,0"
                                           Foreground="{DynamicResource Brush_Txt_Primary}"
                                           FontSize="16" />

                                <!-- 窗口按钮 -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">

                                    <!-- 最小化 -->
                                    <Button Width="40" Height="40"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                                            CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Path Data="M 10 20 L 30 20"
                                              Stroke="{DynamicResource Brush_Txt_Primary}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </Button>

                                    <!-- 最大化 -->
                                    <Button Width="40" Height="40"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{x:Static SystemCommands.MaximizeWindowCommand}"
                                            CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Rectangle Width="16" Height="16"
                                                   Stroke="{DynamicResource Brush_Txt_Primary}"
                                                   StrokeThickness="2" />
                                    </Button>

                                    <!-- 关闭 -->
                                    <Button Width="40" Height="40"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{x:Static SystemCommands.CloseWindowCommand}"
                                            CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Path Data="M 12 12 L 28 28 M 28 12 L 12 28"
                                              Stroke="{DynamicResource Brush_Error}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </Button>

                                </StackPanel>
                            </Grid>

                            <!-- 内容区域 -->
                            <Border Margin="0,48,0,0"
                                    Background="{DynamicResource Brush_Bck_Page}">
                                <ContentPresenter />
                            </Border>

                        </Grid>
                    </Border>

                    <!-- 加载动画 -->
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Window.Loaded">
                            <BeginStoryboard Storyboard="{StaticResource ScaleInStoryboard}" />
                        </EventTrigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>