<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Animations.xaml" />
    </ResourceDictionary.MergedDictionaries>
    <!-- ========================= -->
    <!--   鸿蒙 Dialog 容器（遮罩）  -->
    <!-- ========================= -->
    <Style x:Key="DialogMask" TargetType="Border">
        <Setter Property="Background" Value="#66000000" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>


    <!-- ========================= -->
    <!--   鸿蒙 Dialog 主体样式     -->
    <!-- ========================= -->
    <Style x:Key="Dialog" TargetType="Border">
        <Setter Property="Width" Value="420" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Background" Value="{DynamicResource Brush_Bck_Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Neutral4Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />

        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>

        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#22000000"
                                  BlurRadius="18"
                                  ShadowDepth="4"
                                  Opacity="0.25" />
            </Setter.Value>
        </Setter>

        <Style.Triggers>

            <!-- 加载动效（淡入 + 缩放） -->
            <EventTrigger RoutedEvent="Border.Loaded">
                <BeginStoryboard Storyboard="{StaticResource ScaleInStoryboard}" />
            </EventTrigger>

        </Style.Triggers>
    </Style>



</ResourceDictionary>
