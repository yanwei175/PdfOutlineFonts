<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Animations.xaml" />
    </ResourceDictionary.MergedDictionaries>
    
    <!-- ========================= -->
    <!--   鸿蒙 Card 模板           -->
    <!-- ========================= -->
    <Style TargetType="Border" x:Key="Card">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="{DynamicResource Brush_Bck_Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Neutral4Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />

        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>

        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#22000000"
                                  BlurRadius="12"
                                  ShadowDepth="2"
                                  Opacity="0.15" />
            </Setter.Value>
        </Setter>

        <Style.Triggers>

            <!-- Hover：轻微浮起 -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#33000000"
                                          BlurRadius="16"
                                          ShadowDepth="4"
                                          Opacity="0.25" />
                    </Setter.Value>
                </Setter>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1.01" ScaleY="1.01" />
                    </Setter.Value>
                </Setter>
            </Trigger>

            <!-- 加载动效（淡入 + 缩放） -->
            <EventTrigger RoutedEvent="Border.Loaded">
                <BeginStoryboard Storyboard="{StaticResource ScaleInStoryboard}" />
            </EventTrigger>

        </Style.Triggers>
    </Style>

    <Style x:Key="BaseBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush_Control_Background}"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush_Border_Light}"/>
    </Style>
    
    <Style x:Key="OutLineButtonStyleBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="{DynamicResource Brush_Btn_Default_Background}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush_Btn_Default_Foreground}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0.5" />
    </Style>
</ResourceDictionary>
