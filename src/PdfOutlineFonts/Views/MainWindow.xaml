<Window x:Class="PdfOutlineFonts.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:PdfOutlineFonts.Models"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="PDF 批量转曲工具"
        Icon="/Assets/AppIcon.ico"
        MinWidth="900"
        MinHeight="550"
        Width="1080"
        Height="680">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <StackPanel Orientation="Horizontal">
                <Button Content="添加文件" Style="{StaticResource ButtonPrimary}"  
                        Padding="14,6" Margin="0,0,8,0" Command="{Binding AddFilesCommand}" />
                
                <Button Content="移除选中" Style="{StaticResource ButtonOutline}"
                        Padding="14,6"
                        Margin="0,0,8,0"
                        Command="{Binding RemoveSelectedFilesCommand}"
                        CommandParameter="{Binding SelectedItems, ElementName=FileDataGrid}" />
                <Button Content="清空列表" Style="{StaticResource ButtonDanger}"
                        Padding="14,6" Margin="0,0,8,0" Command="{Binding ClearFilesCommand}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                <TextBlock Text="输出目录:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Width="320" IsReadOnly="True" 
                         Style="{StaticResource MultiLineTextBoxStyle}"
                         Text="{Binding OutputDirectory}" VerticalContentAlignment="Center" />
                <Button Content="选择输出目录" Style="{StaticResource ButtonPrimary}" Padding="14,6" Margin="8,0,0,0" Command="{Binding ChooseOutputDirectoryCommand}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                <Button Content="开始转换" Style="{StaticResource ButtonSuccess}"
                        Padding="14,6" Margin="0,0,8,0" Command="{Binding StartConversionCommand}" />
                <Button Content="取消" Style="{StaticResource ButtonDanger}" Padding="14,6" Command="{Binding CancelConversionCommand}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="0" AllowDrop="True" DragOver="FileList_DragOver" Drop="FileList_Drop">
            <DataGrid x:Name="FileDataGrid"
                      Style="{StaticResource ReadOnlyDataGrid}"
                      ItemsSource="{Binding Files}"
                      AutoGenerateColumns="False"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      IsReadOnly="True"
                      RowHeight="30"
                      SelectionChanged="FileDataGrid_SelectionChanged"
                      KeyDown="FileDataGrid_KeyDown">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="移除选中"
                                  Command="{Binding PlacementTarget.DataContext.RemoveSelectedFilesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="文件名" Width="220" Binding="{Binding FileName}" />
                    <DataGridTextColumn Header="完整路径" Width="*" Binding="{Binding FilePath}" />
                    <DataGridTemplateColumn Header="状态" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:PdfFileItem}">
                                <TextBlock Text="{Binding Status}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="失败">
                                                    <Setter Property="ToolTip" Value="{Binding ErrorMessage}" />
                                                    <Setter Property="Foreground" Value="#C62828" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="进度" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:PdfFileItem}">
                                <ProgressBar Height="16" IsIndeterminate="{Binding IsIndeterminate}" Minimum="0" Maximum="100" Value="0" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StatusBar Grid.Row="4" Background="Transparent">
            <StatusBarItem Width="200">
                <ProgressBar Height="14" Width="180" Minimum="0" Maximum="100" Value="{Binding OverallProgress}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding OverallStatusText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding GhostscriptStatus}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
